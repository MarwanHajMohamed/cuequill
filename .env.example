# Cuequill environment variables.
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.

# ── Core ──────────────────────────────────────────────────────────────
# MongoDB connection string (e.g. a MongoDB Atlas SRV URI).
MONGODB_URI=
# Public base URL of the app, no trailing slash (e.g. https://app.cuequill.com).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth (NextAuth) ───────────────────────────────────────────────────
# Canonical URL NextAuth uses for callbacks; match NEXT_PUBLIC_APP_URL in prod.
NEXTAUTH_URL=http://localhost:3000
# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Google OAuth (Google Cloud console → OAuth client).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Apple "Sign in with Apple" credentials.
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── AI (Quill AI, Google Gemini) ──────────────────────────────────────
# API key from https://aistudio.google.com/apikey (model: gemini-2.5-flash).
GEMINI_API_KEY=
# Optional fair-use caps for Quill AI (per user). Sensible defaults applied
# if unset: 40 messages/day, 10,000,000 tokens/month.
CHAT_DAILY_MESSAGE_LIMIT=40
CHAT_MONTHLY_TOKEN_LIMIT=10000000

# ── Payments (Stripe) ─────────────────────────────────────────────────
# Use test keys (sk_test_… / price_… test) in dev, live keys in production.
STRIPE_SECRET_KEY=
# Signing secret for the /api/stripe webhook endpoint (whsec_…). The Pro
# entitlement depends on this webhook being verified in production.
STRIPE_WEBHOOK_SECRET=
# Price IDs for the two billing cycles.
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# ── Email (Resend) ────────────────────────────────────────────────────
# API key from https://resend.com. Verify the sending domain (SPF/DKIM) so
# transactional mail doesn't land in spam.
RESEND_API_KEY=
# From/reply-to addresses (e.g. "Cuequill <hello@cuequill.com>").
RESEND_FROM=
RESEND_REPLY_TO=

# ── Cron / scheduled jobs ─────────────────────────────────────────────
# Shared secret required by scheduled routes (e.g. IBKR auto-sync). Requests
# must present this so the endpoints can't be triggered by outsiders.
CRON_SECRET=

# ── Broker market-data auth (Interactive Brokers / CME) ───────────────
CME_CLIENT_ID=
CME_CLIENT_SECRET=

# ── Error monitoring (Sentry, optional) ───────────────────────────────
# Leave all unset to disable Sentry entirely (the app runs untouched).
# Server DSN and the public (browser) DSN — usually the same project DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Needed only for build-time source-map upload (nicer stack traces).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
